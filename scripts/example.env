# =============================================================================
# Centralised .env file for all scripts
# Copy this file to scripts/.env and fill in the values
# =============================================================================

# --- Database (PostgreSQL) ---
CONFIG_DB_HOST=
CONFIG_DB_PORT=5432
CONFIG_DB_NAME=
CONFIG_DB_USER=
CONFIG_DB_PASSWORD=

# --- S3 / MinIO ---
S3_ACCESS_KEY_ID=
S3_ACCESS_SECRET_KEY=
S3_ENDPOINT=

# --- Catalog (Iceberg) ---
CATALOG_URI=
CATALOG_WAREHOUSE=
CATALOG_NAME=
CLIENT_ID=
CLIENT_SECRET=

# --- Polaris ---
POLARIS_URL=
POLARIS_REALM=POLARIS
POLARIS_CATALOG_NAME=data_store
POLARIS_PRINCIPAL_NAME=data_store_trino
POLARIS_PRINCIPAL_ROLE_NAME=data_store_user_role
POLARIS_CATALOG_ROLE_NAME=data_store_catalog_role
POLARIS_CA_BUNDLE=

# --- Grist ---
GRIST_TOKEN=
GRIST_DOC_ID=
GRIST_HOST=
GRIST_N8N_PIPELINE_URL=

# --- HTTP ---
HTTP_PROXY_URL=
HTTP_AGENT=

# --- load_config script ---
GRIST_DB_PATH=
LOAD_CONFIG_SCHEMA=conf_projets

# --- load_dataset script ---
LOAD_DATASET_FILE_PATH=
LOAD_DATASET_SCHEMA=
LOAD_DATASET_TABLE_NAME=
LOAD_DATASET_ID_COLNAME=id
LOAD_DATASET_IMPORT_TIMESTAMP=
LOAD_DATASET_SNAPSHOT_ID=
LOAD_DATASET_TSV_FILE_PATH=/tmp/df_result.tsv

# --- generate_tables script ---
GENERATE_TABLES_DOSSIER_PARQUET=
GENERATE_TABLES_FICHIER_SQL=create_tables.sql

# --- S3 user creation ---
S3_USER_ALIAS_NAME=s3_admin
S3_USER_BUCKET=
S3_USER_KEY_ACCESS=*
S3_USER_POLICY_NAME=user-policy
